# === VayuBudhi API — Environment Variables ===
# Copy this file to .env and fill in your keys
# cp .env.example .env

# --- REQUIRED (app won't work well without these) ---

# OpenWeatherMap — https://openweathermap.org/api (free tier: 1000 calls/day)
# Sign up -> API keys -> Copy key
OPENWEATHERMAP_API_KEY=your-key-here

# Anthropic Claude — https://console.anthropic.com
# For multi-agent orchestration (needed for LLM-powered features)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- OPTIONAL (app works without these, uses fallbacks) ---

# Supabase — https://supabase.com/dashboard (free tier)
# Create new project -> Settings -> API -> Copy URL and anon key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# Mapbox — only needed if backend generates map tiles (frontend has its own token)
MAPBOX_TOKEN=pk.your-token

# CPCB API key — not required, app scrapes/generates data without it
CPCB_API_KEY=optional

# --- CONFIG ---
TARGET_CITY=Delhi
DATA_REFRESH_INTERVAL_MINUTES=15
FORECAST_HORIZON_HOURS=72
